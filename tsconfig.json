{
  "compileOnSave": false,
  "files": [],
  "references": [
    { "path": "./projects/go-lib/tsconfig.lib.json" },
    { "path": "./projects/go-lib/tsconfig.spec.json" },
    { "path": "./projects/go-style-guide/tsconfig.app.json" },
    { "path": "./projects/go-style-guide/tsconfig.spec.json" },
    { "path": "./projects/go-tester/tsconfig.app.json" },
    { "path": "./projects/go-tester/tsconfig.spec.json" }
  ],
  "compilerOptions": {
    "baseUrl": "./",
    "importHelpers": true,
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "module": "es2022",
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "useDefineForClassFields": false,
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "ES2022",
      "dom"
    ],
    "paths": {
      "go-lib": [
        "dist/go-lib"
      ],
      "go-lib/*": [
        "dist/go-lib/*"
      ]
    }
  }
}