{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "importHelpers": true,
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "module": "es2022",
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "target": "es2022",
    "rootDir": ".",
    "ignoreDeprecations": "5.0",
    "types": [
      "jasmine",
      "node"
    ],
    "useDefineForClassFields": false,
    "typeRoots": ["node_modules/@types"],
    "lib": ["es2022", "dom"],
    "paths": {
      "go-lib": ["./dist/go-lib"],
      "go-lib/*": ["dist/go-lib/*"]
    }
  }
}
