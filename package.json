{
  "name": "goponents",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mwagz/tangoe-shared.git"
  },
  "author": "Tangoe GoMobile",
  "license": "MIT",
  "scripts": {
    "ng": "node ./node_modules/@angular/cli/bin/ng.js",
    "start": "node ./node_modules/@angular/cli/bin/ng.js serve",
    "build": "node ./node_modules/@angular/cli/bin/ng.js build",
    "test": "npm run test_lib",
    "lint": "node ./node_modules/@angular/cli/bin/ng.js lint",
    "e2e": "node ./node_modules/@angular/cli/bin/ng.js e2e",
    "app": "node ./node_modules/@angular/cli/bin/ng.js build go-tester --configuration production",
    "build_lib": "node ./node_modules/@angular/cli/bin/ng.js build go-lib",
    "build_lib_scss": "chmod +x ./sass-port.sh && ./sass-port.sh",
    "test_lib": "node ./node_modules/@angular/cli/bin/ng.js test go-lib",
    "test_lib:browse": "npm run test_lib -- --reporters=kjhtml --browsers=Chrome",
    "test_lib:detailed": "npm run test_lib -- --reporters=spec",
    "test_lib:coverage": "npm run test_lib -- --code-coverage",
    "test_lib:ci": "npm run test_lib:coverage -- --watch=false",
    "test_app": "node ./node_modules/@angular/cli/bin/ng.js test go-tester",
    "npm_pack": "cd dist/go-lib && npm pack",
    "package": "npm run build_lib && npm run npm_pack",
    "publish": "npm run build_lib && cd dist/go-lib && npm publish",
    "publish_local": "npm run package && node ./local_install.js",
    "sass-lint": "./node_modules/.bin/sass-lint -c .sass-lint.yml",
    "style_guide": "node ./node_modules/@angular/cli/bin/ng.js serve --project=go-style-guide",
    "style_guide_publish": "node ./node_modules/@angular/cli/bin/ng.js build --configuration production --project=go-style-guide",
    "tester": "node ./node_modules/@angular/cli/bin/ng.js serve --project=go-tester",
    "visual_test": "cd visual-tests && npm test",
    "visual_test:update": "cd visual-tests && npm run test:update",
    "visual_test:report": "cd visual-tests && npm run report"
  },
  "private": true,
  "engines": {
    "npm": ">=9.0.0",
    "node": ">=18.13.0 <21"
  },
  "dependencies": {
    "@angular/animations": "18.2.14",
    "@angular/common": "18.2.14",
    "@angular/compiler": "18.2.14",
    "@angular/core": "18.2.14",
    "@angular/forms": "18.2.14",
    "@angular/platform-browser": "18.2.14",
    "@angular/platform-browser-dynamic": "18.2.14",
    "@angular/router": "18.2.14",
    "@ng-select/ng-select": "13.9.1",
    "@tinymce/tinymce-angular": "7.0.0",
    "classlist.js": "1.1.20150312",
    "core-js": "2.5.4",
    "faker": "4.1.0",
    "highlight.js": "11.9.0",
    "ngx-highlightjs": "7.0.0",
    "rxjs": "6.6.7",
    "tinymce": "5.8.0",
    "tslib": "2.8.1",
    "web-animations-js": "2.3.2",
    "zone.js": "0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "18.2.21",
    "@angular-eslint/builder": "18.4.3",
    "@angular-eslint/eslint-plugin": "18.4.3",
    "@angular-eslint/eslint-plugin-template": "18.4.3",
    "@angular-eslint/schematics": "18.4.3",
    "@angular-eslint/template-parser": "18.4.3",
    "@angular/cli": "18.2.21",
    "@angular/compiler-cli": "18.2.14",
    "@angular/language-service": "18.2.14",
    "@typescript-eslint/eslint-plugin": "8.38.0",
    "@typescript-eslint/parser": "8.38.0",
    "@types/jasmine": "2.8.8",
    "@types/jasminewd2": "2.0.3",
    "@types/node": "12.11.1",
    "eslint": "9.31.0",
    "jasmine-core": "3.99.1",
    "jasmine-spec-reporter": "4.2.1",
    "karma": "6.4.4",
    "karma-chrome-launcher": "2.2.0",
    "karma-coverage": "2.2.1",
    "karma-coverage-istanbul-reporter": "3.0.2",
    "karma-jasmine": "2.0.1",
    "karma-jasmine-html-reporter": "1.7.0",
    "karma-spec-reporter": "0.0.32",
    "ng-packagr": "18.2.1",
    "protractor": "7.0.0",
    "sass-lint": "1.13.1",
    "ts-node": "7.0.0",
    "typescript": "5.4.5"
  }
}
